# Supabase (Optional - remove if not using backend)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service-role key — server-side ONLY (seed + import scripts). Bypasses RLS; never
# expose to the browser and never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# PROJ-11 Plant Catalogue ETL — curator's machine only (`npm run import:plants`).
# Anthropic key for AI trait inference: a server-side secret, same trust boundary as
# the service-role key; never shipped to the browser.
ANTHROPIC_API_KEY=your_anthropic_api_key_here
# Optional: override the inference model (defaults to claude-opus-4-8).
# ANTHROPIC_MODEL=claude-opus-4-8
# Optional: override the staging-file path (defaults to plant-import.staging.yaml).
# STAGING_FILE=plant-import.staging.yaml

# Add more environment variables as needed
# STRIPE_SECRET_KEY=sk_...
# SMTP_HOST=smtp.sendgrid.net
# SMTP_USER=your_smtp_user
# SMTP_PASS=your_smtp_password
